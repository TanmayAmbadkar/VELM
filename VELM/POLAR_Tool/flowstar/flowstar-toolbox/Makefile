# Define the C++ compiler.
CXX = g++

# Include a local makefile for project-specific settings.
# The user must ensure makefile.local defines variables like GMP_HOME and GMP_LIB_HOME correctly.
include makefile.local

# Define the libraries to link against.
# We include -lmpfr and -lgmp here, and the -L$(CONDA_PREFIX)/lib flag will point the linker to their location.
LIBS = -lmpfr -lgmp -lgsl -lgslcblas -lm -lglpk

# Define the compilation flags.
# -I. includes the current directory for headers.
# -I$(GMP_HOME) includes the GMP header location.
# -I$(CONDA_PREFIX)/include includes the Conda environment's header directory.
CFLAGS = -I . -I $(GMP_HOME) -I$(CONDA_PREFIX)/include -g -O3 -std=c++11

# Define the linker flags.
# -L$(CONDA_PREFIX)/lib tells the linker to look in the Conda environment's library directory.
# This ensures that the correct version of libmpfr and libgmp is found.
LINK_FLAGS = -g -L $(GMP_LIB_HOME) -L$(CONDA_PREFIX)/lib

# List all object files needed to build the static library.
OBJS = Interval.o Variables.o settings.o Matrix.o Geometry.o Constraints.o Continuous.o Discrete.o Hybrid.o modelParser.tab.o lex.yy.o

# --- Build Targets ---

# Default target builds the static library.
all: libflowstar.a

# Rule to create the static library from all object files.
# `ar` is used to create a static library from object files.
libflowstar.a: $(OBJS)
	ar rcs $@ $^

# --- Compilation rules for different file types ---

%.o: %.cc
	$(CXX) -O3 -c $(CFLAGS) -o $@ $<

%.o: %.cpp
	$(CXX) -O3 -c $(CFLAGS) -o $@ $<

%.o: %.c
	$(CXX) -O3 -c $(CFLAGS) -o $@ $<

# --- Flex and Bison rules ---

# Rule to compile the Flex-generated C file into an object file.
# Depends on the header file generated by Bison.
lex.yy.o: lex.yy.c modelParser.tab.h
	$(CXX) -O3 -c $(CFLAGS) -o $@ $<

# Rule to compile the Bison-generated C file into an object file.
modelParser.tab.o: modelParser.tab.c modelParser.tab.h
	$(CXX) -O3 -c $(CFLAGS) -o $@ $<

# Rule to generate the Bison C source and header files.
modelParser.tab.c modelParser.tab.h: modelParser.y
	bison -d -v $<

# Rule to generate the Flex C source file.
lex.yy.c: modelLexer.l modelParser.tab.h
	flex $<

# --- Phony targets ---

.PHONY: all clean

# The clean target removes all generated files.
clean:
	rm -f $(OBJS) libflowstar.a modelParser.tab.c modelParser.tab.h modelParser.output lex.yy.c
